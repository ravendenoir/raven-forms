# ===========================================
# RAVENFORMS - Environment Variables
# ===========================================
# Copy this to .env and fill in your values
# For Netlify: add these in Site Settings > Environment Variables

# SUPABASE (get from supabase.com > Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# MAILCHIMP (get from mailchimp.com > Account > API Keys)
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your-audience-list-id

# EMAIL NOTIFICATIONS (using Resend - get from resend.com)
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_EMAIL=raven@yourdomain.com
